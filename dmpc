#!/bin/sh

: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"

DMUSIC_CONFIG="${XDG_CONFIG_HOME}/dmusic/config"
[ -f "$DMUSIC_CONFIG" ] && . "$DMUSIC_CONFIG"

: "${DMUSIC_DMENU_PATCHED:=0}"
[ "$DMUSIC_DMENU_PATCHED" = "1" ] && DMENU="dmenu -i -vk" || DMENU="dmenu -i"

: "${SONGS_DIR:=$HOME/songs}"
: "${PLAYLISTS_DIR:=$SONGS_DIR/playlists}"

mpc > /dev/null 2>&1 || {
    notify-send "MPD Error" "Music Player Daemon is not reachable!"
    exit 1
}

# history
CURRENT_SONG=$(mpc current -f "%file%")
HISTORY_FILE="${XDG_DATA_HOME}/dmusic/history.txt"
[ -n "$CURRENT_SONG" ] && {
    mkdir -p "${HISTORY_FILE%/*}"
    touch "$HISTORY_FILE"
    LAST_RECORDED=$(tail -n 1 "$HISTORY_FILE")
    [ "$CURRENT_SONG" != "$LAST_RECORDED" ] && echo "$CURRENT_SONG" >> "$HISTORY_FILE"
}

STATUS=$(mpc status | awk 'NR==2 {print $1}')
[ "$STATUS" = "[playing]" ] && TOGGLE_LABEL="󰏤" || TOGGLE_LABEL="󰐊"

REPEAT_STATUS=$(mpc | awk '/repeat:/ { for(i=1; i<=NF; i++) { if ($i == "repeat:") r = $(i+1); if ($i == "single:") s = $(i+1) } print r, s }')
case "$REPEAT_STATUS" in
    "on on"|"off on")
        REPEAT_LABEL="󰑘"
        ;;
    "on off")
        REPEAT_LABEL="󰑖"
        ;;
    *)
        REPEAT_LABEL="󰑗"
        ;;
esac

# main menu
OPTIONS="󰒮
${TOGGLE_LABEL}
󰒭
${REPEAT_LABEL}
󰒝
󰕮
󰎆
󰲹
󱁴
󰋼
󰉒"

[ -n "$CURRENT_SONG" ] && OPTIONS="${OPTIONS}
󰐕"

CHOICE=$(echo "$OPTIONS" | $DMENU)

# exit on escape
[ -z "$CHOICE" ] && exit 0

case "$CHOICE" in
    "󰒮")
        mpc prev
        ;;
    "󰏤"|"󰐊")
        mpc toggle
        ;;
    "󰒭")
        mpc next
        ;;
    "󰑗"|"󰑖"|"󰑘")
        case "$REPEAT_STATUS" in
            "on on"|"off on")
                mpc repeat off && mpc single off
                notify-send "MPD" "Repeat Mode: Disabled"
                ;;
            "on off")
                mpc repeat on && mpc single on
                notify-send "MPD" "Repeat Mode: Single (Track)"
                ;;
            *)
                mpc repeat on && mpc single off
                notify-send "MPD" "Repeat Mode: Playlist (All)"
                ;;
        esac
        ;;
    "󰒝")
        mpc shuffle
        notify-send "MPD" "Queue shuffled successfully."
        ;;
    "󰕮")
        QUEUE_OPTIONS="[Clear Queue]"
        [ "$DMUSIC_DMENU_PATCHED" != "1" ] && QUEUE_OPTIONS="[..] Go Back
${QUEUE_OPTIONS}"
        TAB=$(printf '\t')
        QUEUE_LIST=$(mpc playlist -f "%position%\t[[%artist% - ]%title%]\t%file%" | while IFS= read -r line; do
            pos="${line%%$TAB*}"
            rest="${line#*$TAB}"
            tags="${rest%%$TAB*}"
            file="${rest#*$TAB}"
            printf "%s\n" "$pos ${tags:-${file##*/}}"
        done)
        SELECTED=$(printf "%s\n%s\n" "$QUEUE_OPTIONS" "$QUEUE_LIST" | $DMENU -l 20 -p "Queue:")
        [ -z "$SELECTED" ] && exec "$0"
        [ "$SELECTED" = "[..] Go Back" ] && exec "$0"

        [ "$SELECTED" = "[Clear Queue]" ] && {
            mpc clear
            notify-send "MPD" "Queue cleared"
        } || {
            INDEX="${SELECTED%% *}"
            [ -n "$INDEX" ] && {
                ACTION=$(printf "Play\nRemove\n" | $DMENU -p "Action:")
                case "$ACTION" in
                    "Play")
                        mpc play "$INDEX"
                        ;;
                    "Remove")
                        mpc del "$INDEX"
                        notify-send "MPD" "Removed song $INDEX from queue"
                        ;;
                esac
            }
        }
        ;;
    "󰎆")
        CURRENT_DIR="${SONGS_DIR}"
        while true; do
            [ "$CURRENT_DIR" = "$SONGS_DIR" ] && {
                # exclude temp and playlists
                LIST=$(ls -1 "$CURRENT_DIR" | sort -f | grep -vE "^(temp|playlists|wishlist\.txt)$")
                [ "$DMUSIC_DMENU_PATCHED" != "1" ] && LIST=$(printf "[..] Go Back\n%s" "$LIST")
                :
            } || {
                DIR_OPTS="[Play Directory Now]
[Add Directory to Queue]"
                [ "$DMUSIC_DMENU_PATCHED" != "1" ] && DIR_OPTS="[..] Go Back
${DIR_OPTS}"
                LIST=$(printf "%s\n%s" "$DIR_OPTS" "$(ls -1 "$CURRENT_DIR" | sort -f)")
            }
            
            SELECTED=$(echo "$LIST" | $DMENU -l 20 -p "Library:")
            EXIT_CODE=$?
            
            [ $EXIT_CODE -eq 1 ] && exit 0
            [ $EXIT_CODE -eq 10 ] && {
                [ "$CURRENT_DIR" != "$SONGS_DIR" ] && { CURRENT_DIR="${CURRENT_DIR%/*}"; continue; } || exec "$0"
            }
            { [ $EXIT_CODE -eq 11 ] || [ $EXIT_CODE -eq 0 ]; } && {
                [ -z "$SELECTED" ] && continue
                
                [ "$SELECTED" = "[..] Go Back" ] && {
                    [ "$CURRENT_DIR" != "$SONGS_DIR" ] && { CURRENT_DIR="${CURRENT_DIR%/*}"; continue; } || exec "$0"
                }

                { [ "$SELECTED" = "[Play Directory Now]" ] || [ "$SELECTED" = "[Add Directory to Queue]" ]; } && {
                    REL_TO_MUSIC_DIR=$(realpath --relative-to="${SONGS_DIR}" "$CURRENT_DIR")
                    [ "$SELECTED" = "[Play Directory Now]" ] && {
                        mpc clear
                        mpc add "$REL_TO_MUSIC_DIR"
                        mpc play
                        notify-send "MPD" "Playing directory: ${CURRENT_DIR##*/}"
                    } || {
                        mpc add "$REL_TO_MUSIC_DIR"
                        notify-send "MPD" "Added directory to queue: ${CURRENT_DIR##*/}"
                    }
                    break
                }

                TARGET="${CURRENT_DIR}/${SELECTED}"
                [ -d "$TARGET" ] && {
                    CURRENT_DIR="$TARGET"
                    continue
                } || {
                    [ -f "$TARGET" ] && {
                        REL_TO_MUSIC_DIR=$(realpath --relative-to="${SONGS_DIR}" "$TARGET")
                        
                        ACTION=$(printf "Play Now\nAdd to Queue\nInsert Next\n" | $DMENU -p "Action:")
                        case "$ACTION" in
                            "Play Now")
                                [ -z "$(mpc current)" ] && { mpc add "$REL_TO_MUSIC_DIR" && mpc play; } || { mpc insert "$REL_TO_MUSIC_DIR" && mpc next; }
                                notify-send "MPD Playing" "${REL_TO_MUSIC_DIR##*/}"
                                ;;
                            "Add to Queue")
                                mpc add "$REL_TO_MUSIC_DIR"
                                notify-send "MPD" "Added to queue: ${REL_TO_MUSIC_DIR##*/}"
                                ;;
                            "Insert Next")
                                mpc insert "$REL_TO_MUSIC_DIR"
                                notify-send "MPD" "Inserted next: ${REL_TO_MUSIC_DIR##*/}"
                                ;;
                        esac
                        break
                    }
                }
            }
        done
        ;;
    "󰲹")
        MENU="[Create Playlist]\n"
        [ "$DMUSIC_DMENU_PATCHED" != "1" ] && MENU="[..] Go Back\n${MENU}"
        for PDIR in "${PLAYLISTS_DIR}"/*/; do
            [ -d "$PDIR" ] || continue
            PDIR_TRIM="${PDIR%/}"
            MENU="${MENU}${PDIR_TRIM##*/}\n"
        done
        SELECTED_PLAYLIST=$(printf "%b" "$MENU" | $DMENU -l 15 -p "Playlists:")
        [ -z "$SELECTED_PLAYLIST" ] && exec "$0"
        [ "$SELECTED_PLAYLIST" = "[..] Go Back" ] && exec "$0"

        [ "$SELECTED_PLAYLIST" = "[Create Playlist]" ] && {
            NEW_PNAME=$(echo "" | dmenu -i -p "New Playlist Name:")
            [ -n "$NEW_PNAME" ] && {
                mkdir -p "${PLAYLISTS_DIR}/${NEW_PNAME}"
                notify-send "MPD" "Playlist '${NEW_PNAME}' created"
            }
        } || {
            ACTION=$(printf "Load (Append)\nLoad (Play Now)\nDelete Playlist\n" | $DMENU -p "Action:")
            PDIR="${PLAYLISTS_DIR}/${SELECTED_PLAYLIST}"
            case "$ACTION" in
                "Load (Append)")
                    COUNT=0
                    for LINK in "${PDIR}"/*; do
                        [ -L "$LINK" ] || continue
                        ABS_TARGET=$(realpath "$LINK")
                        REL_TO_MUSIC_DIR=$(realpath --relative-to="${SONGS_DIR}" "$ABS_TARGET")
                        mpc add "$REL_TO_MUSIC_DIR" && COUNT=$((COUNT + 1))
                    done
                    notify-send "MPD" "Playlist '${SELECTED_PLAYLIST}' (${COUNT} songs) appended to queue"
                    ;;
                "Load (Play Now)")
                    mpc clear
                    COUNT=0
                    for LINK in "${PDIR}"/*; do
                        [ -L "$LINK" ] || continue
                        ABS_TARGET=$(realpath "$LINK")
                        REL_TO_MUSIC_DIR=$(realpath --relative-to="${SONGS_DIR}" "$ABS_TARGET")
                        mpc add "$REL_TO_MUSIC_DIR" && COUNT=$((COUNT + 1))
                    done
                    mpc play
                    notify-send "MPD" "Playing playlist '${SELECTED_PLAYLIST}' (${COUNT} songs)"
                    ;;
                "Delete Playlist")
                    CONFIRM=$(printf "No\nYes\n" | $DMENU -p "Delete playlist '${SELECTED_PLAYLIST}'?")
                    [ "$CONFIRM" = "Yes" ] && {
                        rm -rf "$PDIR"
                        notify-send "MPD" "Playlist '${SELECTED_PLAYLIST}' deleted"
                    }
                    ;;
            esac
        }
        ;;
    "󱁴")
        HISTORY_FILE="${XDG_DATA_HOME}/dmusic/history.txt"
        { [ -f "$HISTORY_FILE" ] && [ -s "$HISTORY_FILE" ]; } && SONG_LIST=$(tac "$HISTORY_FILE" | awk '!seen[$0]++') || SONG_LIST=$(mpc listall)
        
        [ "$DMUSIC_DMENU_PATCHED" != "1" ] && SONG_LIST=$(printf "[..] Go Back\n%s" "$SONG_LIST")
        
        SONG=$(printf "%s" "$SONG_LIST" | $DMENU -l 20 -p "History:")
        [ -z "$SONG" ] && exec "$0"
        [ "$SONG" = "[..] Go Back" ] && exec "$0"

        [ -n "$SONG" ] && {
            pos_raw=$(mpc playlist -f "%file%" | grep -nxF "$SONG" | head -n 1)
            PLAYLIST_POS="${pos_raw%%:*}"
            [ -n "$PLAYLIST_POS" ] && mpc play "$PLAYLIST_POS" || { mpc insert "$SONG" && mpc next; }
            notify-send "MPD Playing" "$(mpc current)"
        }
        ;;
    "󰋼")
        TAB=$(printf '\t')
        CURRENT=$(mpc current -f "%title%\t%file%" | while IFS= read -r line; do
            tags="${line%%$TAB*}"
            file="${line#*$TAB}"
            printf "%s\n" "${tags:-${file##*/}}"
        done)
        [ -n "$CURRENT" ] && notify-send "Currently Playing" "$CURRENT" || notify-send "MPD" "No active song in queue."
        ;;
    "󰉒")
        # collect audio files waiting in temp/
        TEMP_FILES=$(find "${SONGS_DIR}/temp" -type f \
            \( -iname "*.flac" -o -iname "*.mp3" -o -iname "*.opus" \
               -o -iname "*.ogg" -o -iname "*.aac" -o -iname "*.m4a" \) \
            2>/dev/null)

        [ -z "$TEMP_FILES" ] && {
            notify-send "msort" "temp/ is empty, nothing to sort."
            exit 0
        }

        COUNT=$(printf '%s\n' "$TEMP_FILES" | wc -l)
        SORT_MENU="Sort All (${COUNT} file(s))"
        [ "$DMUSIC_DMENU_PATCHED" != "1" ] && SORT_MENU="[..] Go Back\n${SORT_MENU}"
        SELECTED=$(printf '%b\n%s\n' "$SORT_MENU" "$TEMP_FILES" \
            | $DMENU -l 20 -p "Sort temp/:")
        [ -z "$SELECTED" ] && exec "$0"
        [ "$SELECTED" = "[..] Go Back" ] && exec "$0"

        [ "$SELECTED" = "Sort All (${COUNT} file(s))" ] && msort || msort "$SELECTED"
        ;;
    "󰐕")
        # playlist toggle
        FILE="$CURRENT_SONG"
        [ -z "$FILE" ] && {
            notify-send "MPD" "No song currently playing."
            exit 0
        }

        # derive clean symlink name
        ARTIST="${FILE%%/*}"
        TRACK_BASE="${FILE##*/}"
        LINK_NAME="${ARTIST} - ${TRACK_BASE}"

        # resolve absolute path
        ABS_TARGET="${SONGS_DIR}/${FILE}"

        # ensure playlists dir
        mkdir -p "$PLAYLISTS_DIR"

        # interactive loop
        while true; do
            # build menu lines
            MENU=""
            [ "$DMUSIC_DMENU_PATCHED" != "1" ] && MENU="[..] Go Back\n"
            for PDIR in "$PLAYLISTS_DIR"/*/; do
                [ -d "$PDIR" ] || continue
                PDIR_TRIM="${PDIR%/}"
                PNAME="${PDIR_TRIM##*/}"
                [ -L "${PDIR}${LINK_NAME}" ] && MENU="${MENU}󰄲 ${PNAME}\n" || MENU="${MENU}󰄱 ${PNAME}\n"
            done

            [ -z "$MENU" ] && {
                notify-send "Playlists" "No playlists found. Create one with:\nmkdir ~/songs/playlists/MyPlaylist"
                exit 0
            }

            SELECTED=$(printf "%b" "$MENU" | $DMENU -l 15 -p "Playlists (${FILE##*/}):")
            [ -z "$SELECTED" ] && exec "$0"
            [ "$SELECTED" = "[..] Go Back" ] && exec "$0"

            # extract playlist name
            PNAME="${SELECTED#* }"
            PDIR="${PLAYLISTS_DIR}/${PNAME}"
            LINK_PATH="${PDIR}/${LINK_NAME}"

            [ -L "$LINK_PATH" ] && {
                # remove symlink
                rm "$LINK_PATH"
                notify-send "Playlists" "Removed from '${PNAME}'"
            } || {
                # create relative symlink
                REL_TARGET=$(realpath --relative-to="$PDIR" "$ABS_TARGET")
                ln -sf "$REL_TARGET" "$LINK_PATH"
                notify-send "Playlists" "Added to '${PNAME}'"
            }
        done
        ;;
esac
