#!/bin/sh
# smd - Suckless Music Discoverer
# Strictly POSIX compliant shell script. All comments are in english.

# Define dmenu command with styling
DMENU="dmenu -i -vk"

# Setup API credentials (user can override via environment)
API_KEY="${LASTFM_API_KEY:-75d20fb472be99275392aefa2760ea09}"
API_URL="http://ws.audioscrobbler.com/2.0/"

# Wishlist file path
WISHLIST="/home/zukerman/songs/wishlist.txt"

# Ensure curl and jq are available
if ! command -v curl >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
    notify-send "SMD Error" "Missing curl or jq. Please install them."
    exit 1
fi

# URL encoder helper utilizing jq
urlencode() {
    echo "$1" | jq -R -r '@uri'
}

# Fetch JSON helper
fetch_api() {
    # Arguments: $1 = method, $2... = additional query parameters
    METHOD="$1"
    shift
    PARAMS=""
    for PARAM in "$@"; do
        PARAMS="${PARAMS}&${PARAM}"
    done

    RESPONSE=$(curl -s "${API_URL}?method=${METHOD}&api_key=${API_KEY}&format=json${PARAMS}")
    
    # Check for API errors
    ERROR=$(echo "$RESPONSE" | jq -r '.error // empty')
    if [ -n "$ERROR" ]; then
        ERROR_MSG=$(echo "$RESPONSE" | jq -r '.message')
        notify-send "SMD API Error" "$ERROR_MSG"
        exit 1
    fi
    
    echo "$RESPONSE"
}

# Main menu loop
OPTIONS="1. Find Similar Artists
2. Find Similar Tracks (Current Song)
3. Find Similar Tracks (Search Song)
4. Top Tracks by Genre
5. Global Top Charts"

if pgrep -f "mpv --no-video ytdl://" > /dev/null 2>&1; then
    OPTIONS="0. Stop Stream Preview
${OPTIONS}"
fi

CHOICE=$(echo "$OPTIONS" | $DMENU)

case "$CHOICE" in
    "1. Find Similar Artists")
        ARTIST=$(echo "" | dmenu -i -p "Enter Artist Name:")
        [ -z "$ARTIST" ] && exit 0
        
        notify-send "SMD" "Fetching artists similar to '$ARTIST'..."
        ENCODED=$(urlencode "$ARTIST")
        RESPONSE=$(fetch_api "artist.getsimilar" "artist=${ENCODED}" "limit=20")
        
        # Parse artists list
        RESULT=$(echo "$RESPONSE" | jq -r '.similarartists.artist[].name // empty')
        ;;

    "2. Find Similar Tracks (Current Song)")
        # Check if MPD is playing and get current info
        if ! mpc >/dev/null 2>&1; then
            notify-send "SMD Error" "MPD is not running."
            exit 1
        fi
        
        ARTIST=$(mpc current -f "%artist%")
        TRACK=$(mpc current -f "%title%")
        
        if [ -z "$ARTIST" ] || [ -z "$TRACK" ]; then
            notify-send "SMD Info" "No song is currently playing in MPD."
            exit 1
        fi
        
        notify-send "SMD" "Fetching tracks similar to '$ARTIST - $TRACK'..."
        ENCODED_ARTIST=$(urlencode "$ARTIST")
        ENCODED_TRACK=$(urlencode "$TRACK")
        RESPONSE=$(fetch_api "track.getsimilar" "artist=${ENCODED_ARTIST}" "track=${ENCODED_TRACK}" "limit=20")
        
        # Parse tracks list
        RESULT=$(echo "$RESPONSE" | jq -r '.similartracks.track[] | "\(.artist.name) - \(.name)" // empty')
        ;;

    "3. Find Similar Tracks (Search Song)")
        ARTIST=$(echo "" | dmenu -i -p "Enter Artist Name:")
        [ -z "$ARTIST" ] && exit 0
        TRACK=$(echo "" | dmenu -i -p "Enter Track Title:")
        [ -z "$TRACK" ] && exit 0
        
        notify-send "SMD" "Fetching tracks similar to '$ARTIST - $TRACK'..."
        ENCODED_ARTIST=$(urlencode "$ARTIST")
        ENCODED_TRACK=$(urlencode "$TRACK")
        RESPONSE=$(fetch_api "track.getsimilar" "artist=${ENCODED_ARTIST}" "track=${ENCODED_TRACK}" "limit=20")
        
        # Parse tracks list
        RESULT=$(echo "$RESPONSE" | jq -r '.similartracks.track[] | "\(.artist.name) - \(.name)" // empty')
        ;;

    "4. Top Tracks by Genre")
        GENRE=$(echo "" | dmenu -i -p "Enter Genre (e.g. post-punk, synthwave):")
        [ -z "$GENRE" ] && exit 0
        
        notify-send "SMD" "Fetching top tracks for genre '$GENRE'..."
        ENCODED=$(urlencode "$GENRE")
        RESPONSE=$(fetch_api "tag.gettoptracks" "tag=${ENCODED}" "limit=20")
        
        # Parse tracks list
        RESULT=$(echo "$RESPONSE" | jq -r '.toptracks.track[] | "\(.artist.name) - \(.name)" // empty')
        ;;

    "5. Global Top Charts")
        notify-send "SMD" "Fetching global top charts..."
        RESPONSE=$(fetch_api "chart.gettoptracks" "limit=20")
        
        # Parse tracks list
        RESULT=$(echo "$RESPONSE" | jq -r '.tracks.track[] | "\(.artist.name) - \(.name)" // empty')
        ;;
        
    *Stop*|*0.*)
        pkill -f "mpv --no-video ytdl://" >/dev/null 2>&1
        notify-send "SMD" "Preview stopped successfully."
        exit 0
        ;;
        
    *)
        exit 0
        ;;
esac

# Check if we got any results
if [ -z "$RESULT" ]; then
    notify-send "SMD Info" "No recommendations found."
    exit 0
fi

# Show recommendations list to the user
SELECTED=$(echo "$RESULT" | dmenu -i -vk -l 20 -p "Recommendations:")
[ -z "$SELECTED" ] && exit 0

# Select action for the chosen recommendation
ACTION_MENU="󰅍 Copy to Clipboard (Soulseek)
 Stream Preview (mpv/yt-dlp)
󰆓 Add to Wishlist"

ACTION=$(echo "$ACTION_MENU" | dmenu -i -vk)

case "$ACTION" in
    *Copy*)
        echo "$SELECTED" | xclip -sel clip
        notify-send "SMD Clipboard" "Copied to clipboard. Ready to paste in Nicotine+!"
        ;;
        
    *Stream*)
        # Clean up any existing stream previews first
        pkill -f "mpv --no-video ytdl://" >/dev/null 2>&1
        
        notify-send "SMD Stream" "Streaming preview of '$SELECTED' (background)..."
        # Play only audio using mpv with yt-dlp backend in the background
        mpv --no-video "ytdl://ytsearch1:${SELECTED}" >/dev/null 2>&1 &
        ;;
        
    *Wishlist*)
        # Ensure songs directory exists
        mkdir -p "$(dirname "$WISHLIST")"
        echo "$SELECTED" >> "$WISHLIST"
        notify-send "SMD Wishlist" "Added to $WISHLIST"
        ;;
esac
